{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["xinity"],
  "templating": {
    "list": [
      {
        "name": "node",
        "label": "Node",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "xinity-prometheus" },
        "definition": "label_values(daemon_up, node_id)",
        "query": { "qryType": 1, "query": "label_values(daemon_up, node_id)", "refId": "node" },
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": { "text": "All", "value": "$__all", "selected": true },
        "refresh": 2,
        "sort": 1,
        "options": [],
        "regex": "",
        "hide": 0
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Xinity",
  "uid": "xinity",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "type": "row",
      "id": 1,
      "title": "At a glance",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Nodes online",
      "datasource": { "type": "prometheus", "uid": "xinity-prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "textMode": "value"
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "xinity-prometheus" }, "expr": "count(daemon_up == 1) or vector(0)", "instant": true }
      ]
    },
    {
      "type": "stat",
      "id": 3,
      "title": "GPUs",
      "datasource": { "type": "prometheus", "uid": "xinity-prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "textMode": "value"
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "xinity-prometheus" }, "expr": "count(daemon_gpu_info{node_id=~\"$node\"}) or vector(0)", "instant": true }
      ]
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Avg GPU utilization",
      "datasource": { "type": "prometheus", "uid": "xinity-prometheus" },
      "gridPos": { "h": 4, "w": 5, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 } ] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "textMode": "value"
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "xinity-prometheus" }, "expr": "avg(daemon_gpu_utilization_percent{node_id=~\"$node\"})", "instant": false }
      ]
    },
    {
      "type": "stat",
      "id": 5,
      "title": "Total power draw",
      "datasource": { "type": "prometheus", "uid": "xinity-prometheus" },
      "gridPos": { "h": 4, "w": 5, "x": 13, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "watt", "color": { "mode": "fixed", "fixedColor": "orange" } },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "textMode": "value"
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "xinity-prometheus" }, "expr": "sum(daemon_gpu_power_draw_watts{node_id=~\"$node\"})", "instant": false }
      ]
    },
    {
      "type": "stat",
      "id": 6,
      "title": "Energy used (selected range)",
      "datasource": { "type": "prometheus", "uid": "xinity-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "kwatth", "decimals": 2, "color": { "mode": "fixed", "fixedColor": "purple" } },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "textMode": "value"
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "xinity-prometheus" }, "expr": "sum(increase(daemon_gpu_energy_wh_total{node_id=~\"$node\"}[$__range])) / 1000", "instant": true }
      ]
    },

    {
      "type": "row",
      "id": 10,
      "title": "GPU telemetry",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 11,
      "title": "GPU utilization",
      "datasource": { "type": "prometheus", "uid": "xinity-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never", "lineWidth": 1 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "xinity-prometheus" }, "expr": "daemon_gpu_utilization_percent{node_id=~\"$node\"}", "legendFormat": "{{node_id}} · gpu{{gpu}}" }
      ]
    },
    {
      "type": "timeseries",
      "id": 12,
      "title": "GPU memory used (MiB)",
      "datasource": { "type": "prometheus", "uid": "xinity-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes", "min": 0,
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never", "lineWidth": 1 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "xinity-prometheus" }, "expr": "daemon_gpu_memory_used_mb{node_id=~\"$node\"}", "legendFormat": "{{node_id}} · gpu{{gpu}}" }
      ]
    },
    {
      "type": "timeseries",
      "id": 13,
      "title": "GPU temperature",
      "datasource": { "type": "prometheus", "uid": "xinity-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 5, "showPoints": "never", "lineWidth": 1 },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 90 } ] }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "xinity-prometheus" }, "expr": "daemon_gpu_temperature_celsius{node_id=~\"$node\"}", "legendFormat": "{{node_id}} · gpu{{gpu}}" }
      ]
    },
    {
      "type": "timeseries",
      "id": 14,
      "title": "GPU power draw vs limit",
      "datasource": { "type": "prometheus", "uid": "xinity-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "watt", "min": 0,
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never", "lineWidth": 1 }
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*limit.*" }, "properties": [ { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [8, 8] } }, { "id": "custom.fillOpacity", "value": 0 } ] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "xinity-prometheus" }, "expr": "daemon_gpu_power_draw_watts{node_id=~\"$node\"}", "legendFormat": "draw · {{node_id}} gpu{{gpu}}" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "xinity-prometheus" }, "expr": "daemon_gpu_power_limit_watts{node_id=~\"$node\"}", "legendFormat": "limit · {{node_id}} gpu{{gpu}}" }
      ]
    },

    {
      "type": "row",
      "id": 20,
      "title": "Per-GPU triage",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "panels": []
    },
    {
      "type": "bargauge",
      "id": 21,
      "title": "GPU utilization (now)",
      "datasource": { "type": "prometheus", "uid": "xinity-prometheus" },
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 23 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null }, { "color": "green", "value": 20 }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 95 } ] }
        },
        "overrides": []
      },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "showUnfilled": true, "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "xinity-prometheus" }, "expr": "daemon_gpu_utilization_percent{node_id=~\"$node\"} * on(node_id,gpu,uuid) group_left(name) daemon_gpu_info", "instant": true, "legendFormat": "{{node_id}} {{name}} gpu{{gpu}}" }
      ]
    },
    {
      "type": "bargauge",
      "id": 22,
      "title": "GPU memory used (now)",
      "datasource": { "type": "prometheus", "uid": "xinity-prometheus" },
      "gridPos": { "h": 9, "w": 8, "x": 8, "y": 23 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 95 } ] }
        },
        "overrides": []
      },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "showUnfilled": true, "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "xinity-prometheus" }, "expr": "daemon_gpu_memory_utilization_percent{node_id=~\"$node\"}", "instant": true, "legendFormat": "{{node_id}} gpu{{gpu}}" }
      ]
    },
    {
      "type": "table",
      "id": 23,
      "title": "GPU inventory",
      "datasource": { "type": "prometheus", "uid": "xinity-prometheus" },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 23 },
      "fieldConfig": { "defaults": { "custom": { "align": "auto", "filterable": true } }, "overrides": [] },
      "options": { "showHeader": true, "cellHeight": "sm", "footer": { "show": false } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "xinity-prometheus" }, "expr": "daemon_gpu_info{node_id=~\"$node\"}", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "organize", "options": {
          "excludeByName": { "Time": true, "Value": true, "__name__": true, "job": true, "instance": true, "uuid": true },
          "renameByName": { "node_id": "Node", "gpu": "GPU", "name": "Model", "driver_version": "Driver" },
          "indexByName": { "node_id": 0, "gpu": 1, "name": 2, "driver_version": 3 }
        } }
      ]
    },

    {
      "type": "row",
      "id": 30,
      "title": "Health (green = nothing wrong)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "panels": []
    },
    {
      "type": "stat",
      "id": 31,
      "title": "GPUs throttling",
      "datasource": { "type": "prometheus", "uid": "xinity-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 33 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "textMode": "value" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "xinity-prometheus" }, "expr": "count(daemon_gpu_throttled{node_id=~\"$node\"} == 1) or vector(0)", "instant": true }
      ]
    },
    {
      "type": "stat",
      "id": 32,
      "title": "ECC uncorrected errors",
      "datasource": { "type": "prometheus", "uid": "xinity-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 33 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "textMode": "value" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "xinity-prometheus" }, "expr": "sum(daemon_gpu_ecc_errors_total{node_id=~\"$node\",type=\"uncorrected\"}) or vector(0)", "instant": true }
      ]
    },
    {
      "type": "stat",
      "id": 33,
      "title": "Sample failures (rate /5m)",
      "datasource": { "type": "prometheus", "uid": "xinity-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 33 },
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 3,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.001 } ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "textMode": "value" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "xinity-prometheus" }, "expr": "sum(rate(daemon_gpu_sample_failures_total{node_id=~\"$node\"}[5m])) or vector(0)", "instant": false }
      ]
    },
    {
      "type": "stat",
      "id": 34,
      "title": "Scrape targets up",
      "datasource": { "type": "prometheus", "uid": "xinity-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 33 },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] } },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "textMode": "value" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "xinity-prometheus" }, "expr": "sum(up)", "instant": true }
      ]
    },

    {
      "type": "row",
      "id": 40,
      "title": "Energy & power",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 37 },
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 41,
      "title": "Total power draw vs limit",
      "datasource": { "type": "prometheus", "uid": "xinity-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 38 },
      "fieldConfig": {
        "defaults": {
          "unit": "watt", "min": 0,
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15, "showPoints": "never", "lineWidth": 1 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "limit" }, "properties": [ { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [8, 8] } }, { "id": "custom.fillOpacity", "value": 0 }, { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "xinity-prometheus" }, "expr": "sum(daemon_gpu_power_draw_watts{node_id=~\"$node\"})", "legendFormat": "draw" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "xinity-prometheus" }, "expr": "sum(daemon_gpu_power_limit_watts{node_id=~\"$node\"})", "legendFormat": "limit" }
      ]
    },
    {
      "type": "bargauge",
      "id": 42,
      "title": "Energy by node (selected range)",
      "datasource": { "type": "prometheus", "uid": "xinity-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 38 },
      "fieldConfig": {
        "defaults": { "unit": "kwatth", "decimals": 2, "min": 0, "color": { "mode": "continuous-GrYlRd" } },
        "overrides": []
      },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "showUnfilled": true, "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "xinity-prometheus" }, "expr": "sum by (node_id) (increase(daemon_gpu_energy_wh_total{node_id=~\"$node\"}[$__range])) / 1000", "instant": true, "legendFormat": "{{node_id}}" }
      ]
    },

    {
      "type": "row",
      "id": 50,
      "title": "Gateway API & serving throughput",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 46 },
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 51,
      "title": "Request rate by status",
      "datasource": { "type": "prometheus", "uid": "xinity-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 47 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps", "min": 0,
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "stacking": { "mode": "normal", "group": "A" }, "showPoints": "never", "lineWidth": 1 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "xinity-prometheus" }, "expr": "sum by (status) (rate(gateway_requests_total[$__rate_interval]))", "legendFormat": "{{status}}" }
      ]
    },
    {
      "type": "timeseries",
      "id": 52,
      "title": "Average request latency",
      "datasource": { "type": "prometheus", "uid": "xinity-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 47 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms", "min": 0,
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never", "lineWidth": 1 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "xinity-prometheus" }, "expr": "sum by (endpoint) (rate(gateway_request_duration_milliseconds_total[$__rate_interval])) / clamp_min(sum by (endpoint) (rate(gateway_requests_total[$__rate_interval])), 1)", "legendFormat": "{{endpoint}}" }
      ]
    },
    {
      "type": "stat",
      "id": 53,
      "title": "Active requests",
