# Xinity AI Docker Compose Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ══════════════════════════════════════════════════════════════════════════
# REQUIRED SETTINGS
# ══════════════════════════════════════════════════════════════════════════

# Domain Configuration
# Your domain name (without subdomain)
DOMAIN=example.com

# Email for Let's Encrypt SSL certificates
ACME_EMAIL=admin@example.com

# Database Credentials
# PostgreSQL password - use a strong random password
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=

# Redis password - use a strong random password
# Generate with: openssl rand -base64 32
REDIS_PASSWORD=

# Authentication Secret
# Better Auth secret key - MUST be at least 32 characters
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# ══════════════════════════════════════════════════════════════════════════
# OPTIONAL SETTINGS
# ══════════════════════════════════════════════════════════════════════════

# Version / Image Tags
# Specify version tag for all Xinity images (default: latest)
# VERSION=1.0.0

# Database Configuration
POSTGRES_DB=xinity
POSTGRES_USER=xinity

# Subdomain Configuration
# Customize subdomains for each service
DASHBOARD_SUBDOMAIN=dashboard
GATEWAY_SUBDOMAIN=api
INFOSERVER_SUBDOMAIN=sysinfo

# Service Ports (internal)
# Change only if you have conflicts
GATEWAY_PORT=4121
DASHBOARD_PORT=5121
INFOSERVER_PORT=8090
SEARXNG_PORT=8888

# Application Settings
APP_NAME=Xinity Admin
SIGNUP_ENABLED=true
LOG_LEVEL=info

# Infoserver Configuration
# Defaults to the public Xinity model registry at https://sysinfo.xinity.ai
# To host a custom model registry:
# 1. Uncomment INFOSERVER_PROFILE to enable the local infoserver
# 2. Set INFOSERVER_URL to point to your local instance
# 3. Configure models.yaml with your custom models
# INFOSERVER_PROFILE=infoserver
INFOSERVER_URL=https://sysinfo.xinity.ai

# Response Cache
RESPONSE_CACHE_TTL=3600

# SearXNG Configuration
# To disable SearXNG, comment out this line:
SEARXNG_PROFILE=searxng
# SearXNG secret key (change for production)
SEARXNG_SECRET=change-this-secret-key

# ══════════════════════════════════════════════════════════════════════════
# ADVANCED SETTINGS (Optional)
# ══════════════════════════════════════════════════════════════════════════

# Email Configuration (Optional)
# Uncomment and configure for email functionality
# MAIL_URL=smtps://username:password@smtp.example.com:465
# MAIL_FROM=noreply@example.com

# Metrics Authentication (Optional)
# Uncomment to enable basic auth for /metrics endpoint
# Format: username:password
# METRICS_AUTH=admin:secure_password

# Logging Configuration (Optional)
# Axiom log shipping
# AXIOM_DATASET=xinity-logs
# AXIOM_TOKEN=your_axiom_token

# Single-Tenant Mode (Optional)
# Comma-separated list of admin emails
# INSTANCE_ADMIN_EMAILS=admin@example.com,ops@example.com

# ══════════════════════════════════════════════════════════════════════════
# NOTES
# ══════════════════════════════════════════════════════════════════════════

# Security Best Practices:
# 1. Use strong, unique passwords for POSTGRES_PASSWORD and REDIS_PASSWORD
# 2. Generate BETTER_AUTH_SECRET with: openssl rand -base64 32
# 3. Keep this file secure: chmod 600 .env
# 4. Never commit .env to version control (it's in .gitignore)
# 5. Rotate secrets regularly
#
# Secret Files:
# Any env var can be provided via a file by appending _FILE to the var name.
# The file's trimmed contents are used as the value. Direct env vars take
# precedence. This is useful with Docker/Kubernetes secrets:
#   POSTGRES_PASSWORD_FILE=/run/secrets/db_password
#   BETTER_AUTH_SECRET_FILE=/run/secrets/auth_secret
#   REDIS_PASSWORD_FILE=/run/secrets/redis_password

# Service URLs (computed automatically):
# Dashboard:  https://${DASHBOARD_SUBDOMAIN}.${DOMAIN}
# Gateway:    https://${GATEWAY_SUBDOMAIN}.${DOMAIN}
# Infoserver: https://${INFOSERVER_SUBDOMAIN}.${DOMAIN}

# Internal Service Communication:
# Services communicate via Docker network using service names:
# - postgres:5432
# - redis:6379
# - gateway:4121
# - dashboard:5121
# - infoserver:8090
# - searxng:8888
