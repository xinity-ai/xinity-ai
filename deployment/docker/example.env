# Copy this file to .env and fill in your values. Never commit .env.

# Pinned tag for all Xinity images (gateway, dashboard, infoserver).
VERSION=0.19.2

# Postgres + Redis. URL-safe values: openssl rand -hex 32
POSTGRES_PASSWORD=
REDIS_PASSWORD=

# Better Auth signing key, at least 32 chars: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Instance access. Without at least one admin email, the default single-tenant
# mode has no usable admin to bootstrap from.
INSTANCE_ADMIN_EMAILS=admin@example.com
# Set to true to let any signed-up user create their own organization.
MULTI_TENANT_MODE=false
SIGNUP_ENABLED=true

# URLs the dashboard advertises. Defaults serve localhost evaluation, override
# for an HTTPS deployment behind Caddy.
# ORIGIN=https://dashboard.example.com
# HTTP_OVERRIDE_ORIGIN=https://dashboard.example.com
# GATEWAY_URL=https://api.example.com

# Caddy / HTTPS deployment (only used when running `--profile caddy`).
# DOMAIN=example.com
# ACME_EMAIL=admin@example.com
# DASHBOARD_SUBDOMAIN=dashboard
# GATEWAY_SUBDOMAIN=api
# INFOSERVER_SUBDOMAIN=sysinfo

# Database
POSTGRES_DB=xinity
POSTGRES_USER=xinity

# Service ports. Change only on conflict.
GATEWAY_PORT=4121
DASHBOARD_PORT=5121
INFOSERVER_PORT=8090
SEARXNG_PORT=8888

# Display + logging
APP_NAME=Xinity Admin
LOG_LEVEL=info

# Feature toggles (default true; uncomment to disable)
# MCP_ENABLED=false
# COMPUTE_MANAGEMENT_ENABLED=false
# NOTIFICATIONS_ENABLED=false

# Paid licence (unlocks gated features)
# LICENSE_KEY=

# Infoserver. Public registry by default; activate the `infoserver` profile to
# run a private one and point INFOSERVER_URL at it.
INFOSERVER_URL=https://sysinfo.xinity.ai

# Transactional mail
# MAIL_URL=smtps://user:pass@smtp.example.com:465
# MAIL_FROM=noreply@example.com

# Web search via SearXNG. Activate with `--profile searxng`.
# SEARXNG_SECRET=

# Object storage (S3-compatible: SeaweedFS, MinIO, AWS S3, ...)
# S3_ENDPOINT=https://s3.example.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=xinity-media
# S3_REGION=us-east-1

# Basic auth for /metrics endpoints (user:pass, comma-separated for multiple)
# METRICS_AUTH=admin:secret

# CSRF: extra origins permitted by Better Auth
# TRUSTED_ORIGINS=https://other.example.com

# Gateway tuning. Defaults are sane; only set if you know why.
# IDLE_TIMEOUT=255
# LOAD_BALANCE_STRATEGY=least-connections   # random | round-robin | least-connections
# BACKEND_TIMEOUT_MS=300000
RESPONSE_CACHE_TTL=3600
# INFOSERVER_CACHE_TTL_MS=30000

# mTLS to daemons (only if you run inference daemons behind TLS)
# XINITY_INFERENCE_CA=

# Secret files: any VAR can also be supplied as VAR_FILE=/path/to/file
# (Docker / Kubernetes secrets). Direct values take precedence.
