# Copy to .env and fill in. Never commit .env.

VERSION=0.19.2

# openssl rand -hex 32
POSTGRES_PASSWORD=
REDIS_PASSWORD=

# openssl rand -base64 32
BETTER_AUTH_SECRET=

# Required for a usable instance in default single-tenant mode.
INSTANCE_ADMIN_EMAILS=admin@example.com
MULTI_TENANT_MODE=false
SIGNUP_ENABLED=true

# Override for HTTPS deployment (defaults serve localhost).
# ORIGIN=https://dashboard.example.com
# HTTP_OVERRIDE_ORIGIN=https://dashboard.example.com
# GATEWAY_URL=https://api.example.com

# --profile caddy
# DOMAIN=example.com
# ACME_EMAIL=admin@example.com
# DASHBOARD_SUBDOMAIN=dashboard
# GATEWAY_SUBDOMAIN=api
# INFOSERVER_SUBDOMAIN=sysinfo

POSTGRES_DB=xinity
POSTGRES_USER=xinity

GATEWAY_PORT=4121
DASHBOARD_PORT=5121
INFOSERVER_PORT=8090
SEARXNG_PORT=8888

APP_NAME=Xinity Admin
LOG_LEVEL=info

# MCP_ENABLED=false
# COMPUTE_MANAGEMENT_ENABLED=false
# NOTIFICATIONS_ENABLED=false
# LICENSE_KEY=

INFOSERVER_URL=https://sysinfo.xinity.ai

# MAIL_URL=smtps://user:pass@smtp.example.com:465
# MAIL_FROM=noreply@example.com

# --profile searxng
# SEARXNG_SECRET=

# --profile monitoring (Prometheus + Grafana)
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3000
# GRAFANA_ADMIN_PASSWORD=admin

# S3_ENDPOINT=https://s3.example.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=xinity-media
# S3_REGION=us-east-1

# Required by the dashboard (user:pass, comma-separated for multiple).
METRICS_AUTH=admin:secret
# TRUSTED_ORIGINS=https://other.example.com

# IDLE_TIMEOUT=255
# LOAD_BALANCE_STRATEGY=least-connections
# BACKEND_TIMEOUT_MS=300000
RESPONSE_CACHE_TTL=3600
# INFOSERVER_CACHE_TTL_MS=30000

# XINITY_INFERENCE_CA=

# Any VAR can also be supplied as VAR_FILE=/path/to/file.
