{
  "annotations": { "list": [ { "builtIn": 1, "datasource": { "type": "grafana", "uid": "-- Grafana --" }, "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard" } ] },
  "editable": true,
  "graphTooltip": 1,
  "links": [ { "asDropdown": true, "icon": "external link", "includeVars": true, "keepTime": true, "tags": ["xinity-ai"], "title": "Xinity", "type": "dashboards" } ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["xinity-ai"],
  "templating": { "list": [
    { "current": {}, "hide": 0, "includeAll": false, "label": "Prometheus", "multi": false, "name": "DS_PROMETHEUS", "options": [], "query": "prometheus", "refresh": 1, "regex": "", "type": "datasource" },
    {
      "current": { "text": "All", "value": "$__all" },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "definition": "label_values(daemon_up, machine_name)",
      "hide": 0,
      "includeAll": true,
      "label": "Node",
      "multi": true,
      "name": "node",
      "options": [],
      "query": { "qryType": 1, "query": "label_values(daemon_up, machine_name)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
      "refresh": 2,
      "regex": "",
      "allValue": ".*",
      "sort": 1,
      "type": "query"
    }
  ] },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "Xinity GPU / Compute",
  "uid": "xinity-gpu-compute",
  "version": 1,
  "panels": [
    { "type": "row", "id": 1, "title": "GPU / Compute", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },
    {
      "type": "timeseries", "id": 2, "title": "GPU utilization",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never", "lineInterpolation": "smooth" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "editorMode": "code", "expr": "daemon_gpu_utilization_percent{machine_name=~\"$node\"}", "legendFormat": "{{machine_name}} gpu{{gpu}}", "range": true } ]
    },
    {
      "type": "timeseries", "id": 3, "title": "GPU memory used",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "decmbytes", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never", "lineInterpolation": "smooth" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "editorMode": "code", "expr": "daemon_gpu_memory_used_mb{machine_name=~\"$node\"}", "legendFormat": "used {{machine_name}} gpu{{gpu}}", "range": true },
        { "refId": "B", "editorMode": "code", "expr": "daemon_gpu_memory_total_mb{machine_name=~\"$node\"}", "legendFormat": "total {{machine_name}} gpu{{gpu}}", "range": true }
      ]
    },
    {
      "type": "timeseries", "id": 4, "title": "GPU temperature",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "celsius", "custom": { "drawStyle": "line", "fillOpacity": 0, "showPoints": "never", "lineInterpolation": "smooth" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 87 } ] } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "editorMode": "code", "expr": "daemon_gpu_temperature_celsius{machine_name=~\"$node\"}", "legendFormat": "{{machine_name}} gpu{{gpu}}", "range": true } ]
    },
    {
      "type": "timeseries", "id": 5, "title": "GPU power draw vs limit",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "watt", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never", "lineInterpolation": "smooth" } }, "overrides": [ { "matcher": { "id": "byRegexp", "options": "limit.*" }, "properties": [ { "id": "custom.fillOpacity", "value": 0 }, { "id": "custom.lineStyle", "value": { "dash": [8, 4], "fill": "dash" } } ] } ] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "editorMode": "code", "expr": "daemon_gpu_power_draw_watts{machine_name=~\"$node\"}", "legendFormat": "draw {{machine_name}} gpu{{gpu}}", "range": true },
        { "refId": "B", "editorMode": "code", "expr": "daemon_gpu_power_limit_watts{machine_name=~\"$node\"}", "legendFormat": "limit {{machine_name}} gpu{{gpu}}", "range": true }
      ]
    },
    {
      "type": "state-timeline", "id": 6, "title": "GPU throttling",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 80, "lineWidth": 0 }, "mappings": [ { "type": "value", "options": { "0": { "text": "OK", "color": "green" }, "1": { "text": "Throttled", "color": "red" } } } ], "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] },
      "options": { "mergeValues": true, "showValue": "never", "alignValue": "left", "rowHeight": 0.9, "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [ { "refId": "A", "editorMode": "code", "expr": "daemon_gpu_throttled{machine_name=~\"$node\"}", "legendFormat": "{{machine_name}} gpu{{gpu}}", "range": true } ]
    }
  ]
}
