        { "refId": "B", "editorMode": "code", "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(gateway_request_duration_milliseconds_bucket[$__rate_interval])))", "legendFormat": "p95 {{endpoint}}", "range": true }
