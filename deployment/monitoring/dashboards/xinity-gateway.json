        { "refId": "B", "editorMode": "code", "expr": "histogram_quantile(0.95, sum by (le, deployment) (rate(gateway_generation_tokens_per_second_bucket[$__rate_interval])))", "legendFormat": "p95 {{deployment}}", "range": true }
