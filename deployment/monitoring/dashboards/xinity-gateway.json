        { "refId": "B", "editorMode": "code", "expr": "histogram_quantile(0.95, sum by (le, deployment) (rate(gateway_time_to_first_token_milliseconds_bucket[$__rate_interval])))", "legendFormat": "p95 {{deployment}}", "range": true }
