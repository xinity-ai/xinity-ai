{
  "name": "xinity-ai",
  "version": "0.20.1",
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "private": true,
  "scripts": {
    "bump": "bumpp --release conventional --git-check --all --commit --tag --push --execute 'bash scripts/update-changelog.sh'",
    "changelog:preview": "bunx git-cliff --unreleased",
    "postinstall": "if [ -z \"$CI\" ]; then bunx simple-git-hooks@2; fi",
    "sync:dockerfiles": "bun scripts/sync-dockerfile-manifests.ts",
    "sync:dockerfiles:check": "bun scripts/sync-dockerfile-manifests.ts --check",
    "test:system": "bun test --timeout 60000 tests/system/"
  },
  "simple-git-hooks": {
    "commit-msg": "bunx --no-install commitlint --edit $1"
  },
  "type": "module",
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "bumpp": "^11.1.0"
  },
  "overrides": {
    "samlify": "2.13.1",
    "cookie": "^0.7.0",
    "esbuild": "0.27.7"
  }
}
