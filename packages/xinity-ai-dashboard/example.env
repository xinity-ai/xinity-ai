HTTP_PORT=5173
MAIL_URL=smtp://localhost:1025
MAIL_FROM="Auth Service <noreply@example.com>"
# Generate with: openssl rand -base64 33
BETTER_AUTH_SECRET="replace-me"
BETTER_AUTH_URL=http://localhost:5173
GATEWAY_URL=http://localhost:4010
APP_NAME="Xinity Admin"
SIGNUP_ENABLED=true
DB_CONNECTION_URL=postgresql://tester:example@localhost/default
METRICS_AUTH=user:pass
LOG_LEVEL=trace
INFOSERVER_URL=http://localhost:8393
MULTI_TENANT_MODE=true
S3_ENDPOINT=http://localhost:8333
S3_ACCESS_KEY_ID=xinity
S3_SECRET_ACCESS_KEY=xinity-secret
S3_BUCKET=xinity-media
S3_REGION=us-east-1
# Comma-separated emails granted instance-wide admin privileges (e.g. your own email)
INSTANCE_ADMIN_EMAILS=admin@example.com,e2e-owner@xinity-test.local
# Model Context Protocol endpoint at /mcp (true by default)
MCP_ENABLED=true
