		"@orpc/openapi": "^1.11.1",
		"@orpc/server": "^1.11.1",
		"@orpc/zod": "^1.11.1",
		"@sveltejs/kit": "^2.49.4",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
