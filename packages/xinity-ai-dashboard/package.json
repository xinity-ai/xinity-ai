{
	"name": "xinity-ai-dashboard",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "bun --bun vite dev --port 5173 | pino-pretty",
		"build": "bun --bun vite build",
		"build:compile": "bun run build.ts",
		"preview": "bun --bun vite preview --port 5173 | pino-pretty",
		"prepare": "bun --bun svelte-kit sync || echo ''",
		"check": "bun --bun svelte-kit sync && bun --bun  svelte-check --tsconfig ./tsconfig.json",
		"test": "bun test --timeout 60000",
		"test:api": "bun test --timeout 60000 e2e/api/",
		"test:headed": "HEADED=1 bun test --timeout 60000 e2e/",
		"test:setup": "bun run e2e/global-setup.ts"
	},
	"devDependencies": {
		"@better-auth/passkey": "^1.6.9",
		"@eslym/sveltekit-adapter-bun": "^2.1.1",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^1.14.0",
		"@orpc/client": "^1.14.0",
		"@orpc/openapi": "^1.14.0",
		"@orpc/server": "^1.14.0",
		"@orpc/zod": "^1.14.0",
		"@sveltejs/kit": "^2.58.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.4",
		"@types/mjml": "^5.0.0",
		"@types/nodemailer": "^8.0.0",
		"@types/prismjs": "^1.26.6",
		"better-auth": "^1.6.9",
		"bits-ui": "^2.18.0",
		"chart.js": "^4.5.1",
		"clsx": "^2.1.1",
		"common-db": "workspace:*",
		"common-env": "workspace:*",
		"marked": "^17.0.6",
		"pino-pretty": "^13.1.3",
		"playwright-core": "^1.59.1",
		"prismjs": "^1.30.0",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.6",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.4",
		"tslib": "^2.8.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.2",
		"vite-plugin-devtools-json": "^1.0.0",
		"xinity-infoserver": "workspace:*",
		"zod": "^4.3.6"
	},
	"dependencies": {
		"@better-auth/api-key": "^1.6.9",
		"@better-auth/sso": "^1.6.9",
		"@types/bun": "^1.3.13",
		"common-log": "workspace:*",
		"mjml": "^5.1.0",
		"nodemailer": "^8.0.7",
		"pino": "^10.3.1",
		"prom-client": "^15.1.3"
	}
}
