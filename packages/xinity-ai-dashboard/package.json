{
	"name": "xinity-ai-dashboard",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "bun --bun vite dev --port 5173 | pino-pretty",
		"build": "bun --bun vite build",
		"preview": "bun --bun vite preview --port 5173 | pino-pretty",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"test": "bun test --timeout 60000",
		"test:api": "bun test --timeout 60000 e2e/api/",
		"test:headed": "HEADED=1 bun test --timeout 60000 e2e/",
		"test:setup": "bun run e2e/global-setup.ts"
	},
