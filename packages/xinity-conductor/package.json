{
  "name": "xinity-conductor",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts | pino-pretty",
    "build": "bun build --production --target=bun --outdir=dist ./src/index.ts",
    "build:compile": "bun build --compile --minify --target=bun ./src/index.ts --outfile xinity-conductor",
    "test": "bun test src/"
  },
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "common-db": "workspace:*",
    "common-env": "workspace:*",
    "common-log": "workspace:*",
    "pino-pretty": "^13.1.2",
    "zod": "^4.2.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
