{
  "name": "xinity-cli",
  "type": "module",
  "private": true,
  "main": "src/index.ts",
  "bin": {
    "xinity": "src/index.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun run build.ts",
    "test": "bun test --timeout 30000 tests/",
    "test:unit": "bun test --timeout 15000 tests/unit/",
    "test:integration": "bun test --timeout 30000 tests/integration/"
  },
  "devDependencies": {
    "@clack/prompts": "^1.4.0",
    "@orpc/server": "^1.14.3",
    "@types/bun": "^1.3.14",
    "@types/yargs": "^17.0.35",
    "common-db": "workspace:*",
    "common-env": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "picocolors": "^1.1.1",
    "postgres": "^3.4.9",
    "xinity-ai-daemon": "workspace:*",
    "xinity-ai-dashboard": "workspace:*",
    "xinity-ai-gateway": "workspace:*",
    "xinity-infoserver": "workspace:*",
    "yargs": "^17.7.2",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
