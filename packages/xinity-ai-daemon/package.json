{
  "name": "xinity-ai-daemon",
  "main": "src/index.ts",
  "devDependencies": {
    "@orpc/openapi": "^1.14.3",
    "@orpc/server": "^1.14.3",
    "@orpc/zod": "^1.14.3",
    "@types/bun": "^1.3.14",
    "common-db": "workspace:*",
    "common-env": "workspace:*",
    "common-log": "workspace:*",
    "pino-pretty": "^13.1.3",
    "xinity-infoserver": "workspace:*",
    "ollama": "^0.6.3",
    "postgres": "^3.4.9",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "scripts": {
    "dev": "bun run --watch src/index | pino-pretty",
    "build": "bun build --production --target=bun --outdir=dist ./src/index.ts",
    "build:compile": "bun build --compile --minify --target=bun ./src/index.ts --outfile xinity-ai-daemon",
    "test": "bun test src/",
    "print-vllm-command": "bun run src/scripts/print-vllm-command.ts"
  },
  "type": "module"
}