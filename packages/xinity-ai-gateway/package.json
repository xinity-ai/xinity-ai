{
  "name": "xinity-ai-gateway",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/gatewayServer.ts | pino-pretty",
    "build": "bun build --production --target=bun  --outdir=dist ./src/gatewayServer.ts",
    "build:compile": "bun build --compile --minify --target=bun ./src/gatewayServer.ts --outfile xinity-ai-gateway",
    "test": "bun test src/"
  },
  "devDependencies": {
    "@orpc/client": "^1.10.1",
    "@orpc/openapi": "^1.10.0",
    "@orpc/server": "^1.10.0",
    "@orpc/zod": "^1.10.0",
    "@types/bun": "^1.3.6",
    "drizzle-orm": "^0.44.7",
    "common-db": "workspace:*",
    "common-log": "workspace:*",
    "xinity-infoserver": "workspace:*",
    "common-env": "workspace:*",
    "pino-pretty": "^13.1.2",
    "rambdax": "^11.3.1",
    "zod": "^4.1.12",
    "rambda": "^10.3.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.31",
    "ai": "^6.0.78"
  }
}